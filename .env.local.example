# ── Flex Connect Demo — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# The base URL of the Flex Core API
FLEX_API_URL=https://api.gosurge.xyz

# The merchant ID of the demo merchant account (created in the Surge admin)
DEMO_MERCHANT_ID=mer_xxxxxxxxxxxx

# The JWT token of the demo merchant — obtained via POST /api/v1/auth/login
# This key is used SERVER-SIDE ONLY inside the /api/create-session route.
# It is NEVER sent to the browser.
DEMO_MERCHANT_SECRET_KEY=eyJhbGci...your_jwt_token_here
