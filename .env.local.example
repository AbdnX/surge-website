# ── Surge Demo — Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# The base URL of the Surge API
FLEX_API_URL=https://api.gosurge.xyz

# Credentials for the dedicated demo merchant account (created at merchant.gosurge.xyz/register)
# The server uses these to auto-login and obtain a fresh JWT before every checkout session.
# These values NEVER reach the browser — they are used server-side only.
DEMO_MERCHANT_EMAIL=demo@gosurge.xyz
DEMO_MERCHANT_PASSWORD=your_demo_account_password
